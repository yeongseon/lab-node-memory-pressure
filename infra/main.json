{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.41.2.15936",
      "templateHash": "15749958317421335497"
    }
  },
  "parameters": {
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region. Defaults to resource group location."
      }
    },
    "namePrefix": {
      "type": "string",
      "defaultValue": "memlabnode",
      "maxLength": 12,
      "metadata": {
        "description": "Prefix for all resource names. Must be lowercase letters and numbers only."
      }
    },
    "planSku": {
      "type": "string",
      "defaultValue": "B1",
      "allowedValues": [
        "B1",
        "B2",
        "S1"
      ],
      "metadata": {
        "description": "App Service Plan SKU. B1/B2 for Basic, S1 for Standard."
      }
    },
    "appCount": {
      "type": "int",
      "defaultValue": 2,
      "minValue": 1,
      "maxValue": 15,
      "metadata": {
        "description": "Number of Web Apps to deploy on the same plan."
      }
    },
    "allocMbPerApp": {
      "type": "int",
      "defaultValue": 100,
      "minValue": 10,
      "maxValue": 500,
      "metadata": {
        "description": "Memory to allocate per app at startup (MB)."
      }
    },
    "deployMode": {
      "type": "string",
      "defaultValue": "zip",
      "allowedValues": [
        "zip",
        "container"
      ],
      "metadata": {
        "description": "Deployment mode: zip for ZIP deploy, container for Web App for Containers."
      }
    },
    "containerImage": {
      "type": "string",
      "defaultValue": "",
      "metadata": {
        "description": "Container image reference (for example myregistry.azurecr.io/app:latest). Used only when deployMode=container."
      }
    },
    "deployAcr": {
      "type": "bool",
      "defaultValue": false,
      "metadata": {
        "description": "Deploy Azure Container Registry module."
      }
    },
    "acrName": {
      "type": "string",
      "defaultValue": "[format('{0}acr', parameters('namePrefix'))]",
      "metadata": {
        "description": "ACR name. Must be globally unique and alphanumeric only."
      }
    },
    "instanceCount": {
      "type": "int",
      "defaultValue": 1,
      "minValue": 1,
      "maxValue": 3,
      "metadata": {
        "description": "Number of App Service Plan workers (instances)."
      }
    }
  },
  "variables": {
    "planName": "[format('{0}-plan', parameters('namePrefix'))]"
  },
  "resources": [
    {
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "deploy-plan",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "planName": {
            "value": "[variables('planName')]"
          },
          "location": {
            "value": "[parameters('location')]"
          },
          "planSku": {
            "value": "[parameters('planSku')]"
          },
          "instanceCount": {
            "value": "[parameters('instanceCount')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.41.2.15936",
              "templateHash": "14930431628040369887"
            }
          },
          "parameters": {
            "planName": {
              "type": "string",
              "metadata": {
                "description": "App Service Plan name"
              }
            },
            "location": {
              "type": "string",
              "metadata": {
                "description": "Azure region"
              }
            },
            "planSku": {
              "type": "string",
              "metadata": {
                "description": "App Service Plan SKU"
              }
            },
            "instanceCount": {
              "type": "int",
              "metadata": {
                "description": "Number of worker instances for the plan"
              }
            }
          },
          "resources": [
            {
              "type": "Microsoft.Web/serverfarms",
              "apiVersion": "2023-01-01",
              "name": "[parameters('planName')]",
              "location": "[parameters('location')]",
              "kind": "linux",
              "sku": {
                "name": "[parameters('planSku')]",
                "capacity": "[parameters('instanceCount')]"
              },
              "properties": {
                "reserved": true
              }
            }
          ],
          "outputs": {
            "planId": {
              "type": "string",
              "value": "[resourceId('Microsoft.Web/serverfarms', parameters('planName'))]"
            },
            "planName": {
              "type": "string",
              "value": "[parameters('planName')]"
            }
          }
        }
      }
    },
    {
      "condition": "[parameters('deployAcr')]",
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "deploy-acr",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "acrName": {
            "value": "[parameters('acrName')]"
          },
          "location": {
            "value": "[parameters('location')]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.41.2.15936",
              "templateHash": "1678575381830151459"
            }
          },
          "parameters": {
            "acrName": {
              "type": "string",
              "metadata": {
                "description": "Azure Container Registry name. Must be globally unique and alphanumeric only."
              }
            },
            "location": {
              "type": "string",
              "metadata": {
                "description": "Azure region"
              }
            }
          },
          "resources": [
            {
              "type": "Microsoft.ContainerRegistry/registries",
              "apiVersion": "2023-07-01",
              "name": "[parameters('acrName')]",
              "location": "[parameters('location')]",
              "sku": {
                "name": "Basic"
              },
              "properties": {
                "adminUserEnabled": true
              }
            }
          ],
          "outputs": {
            "acrLoginServer": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.ContainerRegistry/registries', parameters('acrName')), '2023-07-01').loginServer]"
            },
            "acrName": {
              "type": "string",
              "value": "[parameters('acrName')]"
            }
          }
        }
      }
    },
    {
      "copy": {
        "name": "webApps",
        "count": "[length(range(0, parameters('appCount')))]"
      },
      "type": "Microsoft.Resources/deployments",
      "apiVersion": "2025-04-01",
      "name": "[format('deploy-webapp-{0}', add(range(0, parameters('appCount'))[copyIndex()], 1))]",
      "properties": {
        "expressionEvaluationOptions": {
          "scope": "inner"
        },
        "mode": "Incremental",
        "parameters": {
          "appName": {
            "value": "[format('{0}-{1}', parameters('namePrefix'), add(range(0, parameters('appCount'))[copyIndex()], 1))]"
          },
          "location": {
            "value": "[parameters('location')]"
          },
          "planId": {
            "value": "[reference(resourceId('Microsoft.Resources/deployments', 'deploy-plan'), '2025-04-01').outputs.planId.value]"
          },
          "allocMb": {
            "value": "[parameters('allocMbPerApp')]"
          },
          "deployMode": {
            "value": "[parameters('deployMode')]"
          },
          "containerImage": {
            "value": "[parameters('containerImage')]"
          },
          "acrLoginServer": "[if(parameters('deployAcr'), createObject('value', reference(resourceId('Microsoft.Resources/deployments', 'deploy-acr'), '2025-04-01').outputs.acrLoginServer.value), createObject('value', ''))]",
          "acrName": "[if(parameters('deployAcr'), createObject('value', reference(resourceId('Microsoft.Resources/deployments', 'deploy-acr'), '2025-04-01').outputs.acrName.value), createObject('value', ''))]",
          "acrResourceGroupName": {
            "value": "[resourceGroup().name]"
          }
        },
        "template": {
          "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
          "contentVersion": "1.0.0.0",
          "metadata": {
            "_generator": {
              "name": "bicep",
              "version": "0.41.2.15936",
              "templateHash": "649827544778559908"
            }
          },
          "parameters": {
            "appName": {
              "type": "string",
              "metadata": {
                "description": "Web App name. Must be globally unique."
              }
            },
            "location": {
              "type": "string",
              "metadata": {
                "description": "Azure region"
              }
            },
            "planId": {
              "type": "string",
              "metadata": {
                "description": "App Service Plan resource ID"
              }
            },
            "allocMb": {
              "type": "int",
              "metadata": {
                "description": "Memory to allocate on startup (MB)"
              }
            },
            "deployMode": {
              "type": "string",
              "allowedValues": [
                "zip",
                "container"
              ],
              "metadata": {
                "description": "Deployment mode: zip or container"
              }
            },
            "containerImage": {
              "type": "string",
              "defaultValue": "",
              "metadata": {
                "description": "Container image reference. Used only when deployMode=container."
              }
            },
            "acrLoginServer": {
              "type": "string",
              "defaultValue": "",
              "metadata": {
                "description": "ACR login server (e.g. myregistry.azurecr.io)."
              }
            },
            "acrName": {
              "type": "string",
              "defaultValue": "",
              "metadata": {
                "description": "ACR name for resolving admin credentials."
              }
            },
            "acrResourceGroupName": {
              "type": "string",
              "metadata": {
                "description": "Resource group name containing ACR."
              }
            }
          },
          "variables": {
            "useContainer": "[equals(parameters('deployMode'), 'container')]",
            "useAcrCredentials": "[and(variables('useContainer'), not(empty(parameters('acrName'))))]",
            "linuxFxVersion": "[if(variables('useContainer'), format('DOCKER|{0}', parameters('containerImage')), 'NODE|20-lts')]",
            "startupCommand": "[if(variables('useContainer'), '', 'node server.mjs')]",
            "dockerRegistryServerUrl": "[if(not(empty(parameters('acrLoginServer'))), format('https://{0}', parameters('acrLoginServer')), '')]",
            "baseAppSettings": [
              {
                "name": "ALLOC_MB",
                "value": "[string(parameters('allocMb'))]"
              },
              {
                "name": "APP_NAME",
                "value": "[parameters('appName')]"
              },
              {
                "name": "ENABLE_DIAG",
                "value": "true"
              },
              {
                "name": "SCM_DO_BUILD_DURING_DEPLOYMENT",
                "value": "false"
              },
              {
                "name": "ENABLE_ORYX_BUILD",
                "value": "false"
              },
              {
                "name": "WEBSITES_PORT",
                "value": "8080"
              }
            ],
            "zipOnlyAppSettings": "[if(not(variables('useContainer')), createArray(createObject('name', 'WEBSITE_NODE_DEFAULT_VERSION', 'value', '~20')), createArray())]"
          },
          "resources": [
            {
              "type": "Microsoft.Web/sites",
              "apiVersion": "2023-01-01",
              "name": "[parameters('appName')]",
              "location": "[parameters('location')]",
              "kind": "[if(variables('useContainer'), 'app,linux,container', 'app,linux')]",
              "properties": {
                "serverFarmId": "[parameters('planId')]",
                "reserved": true,
                "httpsOnly": true,
                "siteConfig": {
                  "linuxFxVersion": "[variables('linuxFxVersion')]",
                  "alwaysOn": true,
                  "appCommandLine": "[variables('startupCommand')]",
                  "appSettings": "[concat(variables('baseAppSettings'), variables('zipOnlyAppSettings'), if(variables('useContainer'), createArray(createObject('name', 'DOCKER_REGISTRY_SERVER_URL', 'value', variables('dockerRegistryServerUrl')), createObject('name', 'DOCKER_REGISTRY_SERVER_USERNAME', 'value', if(variables('useAcrCredentials'), listCredentials(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('acrResourceGroupName')), 'Microsoft.ContainerRegistry/registries', parameters('acrName')), '2023-07-01').username, '')), createObject('name', 'DOCKER_REGISTRY_SERVER_PASSWORD', 'value', if(variables('useAcrCredentials'), listCredentials(extensionResourceId(format('/subscriptions/{0}/resourceGroups/{1}', subscription().subscriptionId, parameters('acrResourceGroupName')), 'Microsoft.ContainerRegistry/registries', parameters('acrName')), '2023-07-01').passwords[0].value, ''))), createArray()))]",
                  "healthCheckPath": "/health"
                }
              }
            }
          ],
          "outputs": {
            "defaultHostname": {
              "type": "string",
              "value": "[reference(resourceId('Microsoft.Web/sites', parameters('appName')), '2023-01-01').defaultHostName]"
            },
            "appName": {
              "type": "string",
              "value": "[parameters('appName')]"
            }
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Resources/deployments', 'deploy-acr')]",
        "[resourceId('Microsoft.Resources/deployments', 'deploy-plan')]"
      ]
    }
  ],
  "outputs": {
    "planName": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'deploy-plan'), '2025-04-01').outputs.planName.value]"
    },
    "planId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'deploy-plan'), '2025-04-01').outputs.planId.value]"
    },
    "appHostnames": {
      "type": "array",
      "copy": {
        "count": "[length(range(0, parameters('appCount')))]",
        "input": "[reference(resourceId('Microsoft.Resources/deployments', format('deploy-webapp-{0}', add(range(0, parameters('appCount'))[range(0, parameters('appCount'))[copyIndex()]], 1))), '2025-04-01').outputs.defaultHostname.value]"
      }
    },
    "appNames": {
      "type": "array",
      "copy": {
        "count": "[length(range(0, parameters('appCount')))]",
        "input": "[reference(resourceId('Microsoft.Resources/deployments', format('deploy-webapp-{0}', add(range(0, parameters('appCount'))[range(0, parameters('appCount'))[copyIndex()]], 1))), '2025-04-01').outputs.appName.value]"
      }
    },
    "acrLoginServer": {
      "type": "string",
      "value": "[if(parameters('deployAcr'), reference(resourceId('Microsoft.Resources/deployments', 'deploy-acr'), '2025-04-01').outputs.acrLoginServer.value, '')]"
    }
  }
}